{
  "name": "gargotte-adventure",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Jeu de plateau numérique coopératif Gargotte & Va-Nu-Pieds.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run validate:content && npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:content": "tsx tools/validators/src/validate-content.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run validate:content && npm run typecheck && npm run test && npm run build",
    "validate:repository": "python3 tools/validate_repository.py"
  },
  "dependencies": {
    "idb": "8.0.3",
    "pixi.js": "8.19.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "fake-indexeddb": "6.2.5",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
